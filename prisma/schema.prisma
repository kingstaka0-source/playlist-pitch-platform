generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id                    String             @id @default(cuid())
  clerkUserId           String?            @unique
  name                  String
  email                 String?            @unique
  spotifyId             String?            @unique
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?
  spotifyScopes         String?
  createdAt             DateTime           @default(now())
  plan                  Plan               @default(FREE)
  trialUntil            DateTime?
  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  subscriptionStatus    SubscriptionStatus @default(NONE)
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  tracks                Track[]
}

model Track {
  id             String   @id @default(cuid())
  artistId       String
  spotifyTrackId String   @unique
  title          String
  artists        String[]
  durationMs     Int
  audioFeatures  Json
  genres         String[]
  createdAt      DateTime @default(now())
  matches        Match[]
  artist         Artist   @relation(fields: [artistId], references: [id])
}

model Curator {
  id                String        @id @default(cuid())
  name              String
  email             String?       @unique
  contactMethod     ContactMethod
  consent           Boolean       @default(true)
  languages         String[]      @default(["en"])
  createdAt         DateTime      @default(now())
  contactConfidence Int           @default(0)
  contactSourceUrl  String?
  enrichmentNotes   String?
  instagramUrl      String?
  lastEnrichedAt    DateTime?
  submissionUrl     String?
  websiteUrl        String?
  playlists         Playlist[]
}

model Playlist {
  id                String       @id @default(cuid())
  curatorId         String
  name              String
  spotifyPlaylistId String?
  genres            String[]
  minBpm            Int?
  maxBpm            Int?
  minEnergy         Float?
  maxEnergy         Float?
  rules             Json?
  createdAt         DateTime     @default(now())
  description       String?
  ownerDisplayName  String?
  ownerSpotifyId    String?
  spotifyUrl        String?
  matches           Match[]
  curator           Curator      @relation(fields: [curatorId], references: [id])
  tasteEvents       TasteEvent[]
}

model TasteEvent {
  id             String     @id @default(cuid())
  playlistId     String
  spotifyTrackId String
  label          TasteLabel
  createdAt      DateTime   @default(now())
  playlist       Playlist   @relation(fields: [playlistId], references: [id])
}

model Match {
  id          String   @id @default(cuid())
  trackId     String
  playlistId  String
  fitScore    Int
  explanation String
  createdAt   DateTime @default(now())
  playlist    Playlist @relation(fields: [playlistId], references: [id])
  track       Track    @relation(fields: [trackId], references: [id])
  pitch       Pitch?

  @@unique([trackId, playlistId], name: "trackId_playlistId")
}

model CampaignHistory {
  id              String   @id @default(cuid())
  trackId         String
  matchesCount    Int      @default(0)
  placementsCount Int      @default(0)
  successRate     Int      @default(0)
  createdAt       DateTime @default(now())
}

model Pitch {
  id               String      @id @default(cuid())
  matchId          String      @unique
  subject          String
  body             String
  channel          Channel
  status           PitchStatus @default(DRAFT)
  createdAt        DateTime    @default(now())
  sentAt           DateTime?
  sentTo           String?
  updatedAt        DateTime    @updatedAt
  playlistDetected Boolean     @default(false)
  playlistedAt     DateTime?
  clickCount       Int         @default(0)
  lastClickedAt    DateTime?
  lastOpenedAt     DateTime?
  lastRepliedAt    DateTime?
  negativeReply    Boolean?
  openCount        Int         @default(0)
  positiveReply    Boolean?
  replyCount       Int         @default(0)
  followUpSent     Boolean     @default(false)
  followUpSentAt   DateTime?
  match            Match       @relation(fields: [matchId], references: [id])
}

model AgreementAcceptance {
  id          String               @id @default(cuid())
  subjectType AgreementSubjectType
  subjectId   String
  docType     AgreementDocType
  version     String
  acceptedAt  DateTime             @default(now())
  ip          String?
  userAgent   String?
  meta        Json?

  @@unique([subjectType, subjectId, docType, version], name: "subject_doc_version_unique")
  @@index([subjectType, subjectId], map: "subject_lookup")
}

model MatchJob {
  id          String         @id @default(cuid())
  status      MatchJobStatus @default(QUEUED)
  trackId     String
  artistId    String?
  runAt       DateTime       @default(now())
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  result      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, runAt])
  @@index([trackId])
  @@index([lockedAt])
}

enum ContactMethod {
  INAPP
  EMAIL
}

enum TasteLabel {
  ADDED
  SKIPPED
  LIKED
}

enum Channel {
  INAPP
  EMAIL
}

enum PitchStatus {
  DRAFT
  QUEUED
  SENT
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum AgreementSubjectType {
  ARTIST
  CURATOR
}

enum AgreementDocType {
  TERMS
  PRIVACY
  PITCH_CONSENT
  BILLING_TERMS
}

enum MatchJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}
