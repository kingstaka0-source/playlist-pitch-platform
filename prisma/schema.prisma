generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  spotifyId  String?  @unique

  // Spotify auth
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?
  spotifyScopes         String? // optioneel: "user-read-email user-read-private"

  createdAt  DateTime @default(now())

  plan       Plan     @default(FREE)
  trialUntil DateTime?

  // Stripe...
  stripeCustomerId      String? @unique
  stripeSubscriptionId  String? @unique
  subscriptionStatus    SubscriptionStatus @default(NONE)
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean @default(false)

  tracks Track[]
}





model Track {
  id              String   @id @default(cuid())
  artistId        String
  artist          Artist   @relation(fields: [artistId], references: [id])
  spotifyTrackId  String   @unique
  title           String
  artists         String[]
  durationMs      Int
  audioFeatures   Json
  genres          String[]
  createdAt       DateTime @default(now())
  matches         Match[]
}

model Curator {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  contactMethod ContactMethod
  consent       Boolean  @default(true)
  languages     String[] @default(["en"])
  createdAt     DateTime @default(now())
  playlists     Playlist[]
}

enum ContactMethod {
  INAPP
  EMAIL
}

model Playlist {
  id                String   @id @default(cuid())
  curatorId         String
  curator           Curator  @relation(fields: [curatorId], references: [id])
  name              String
  spotifyPlaylistId String?
  genres            String[]
  minBpm            Int?
  maxBpm            Int?
  minEnergy         Float?
  maxEnergy         Float?
  rules             Json?
  createdAt         DateTime @default(now())
  tasteEvents       TasteEvent[]
  matches           Match[]
}

model TasteEvent {
  id             String   @id @default(cuid())
  playlistId     String
  playlist       Playlist @relation(fields: [playlistId], references: [id])
  spotifyTrackId String
  label          TasteLabel
  createdAt      DateTime @default(now())
}

enum TasteLabel {
  ADDED
  SKIPPED
  LIKED
}

model Match {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id])
  fitScore    Int
  explanation String
  createdAt   DateTime @default(now())
  pitch       Pitch?
  @@unique([trackId, playlistId], name: "trackId_playlistId")
}

model Pitch {
  id        String      @id @default(cuid())
  matchId   String      @unique
  match     Match       @relation(fields: [matchId], references: [id])
  subject   String
  body      String
  channel   Channel
  status    PitchStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  sentAt    DateTime?
  sentTo    String?
  updatedAt DateTime    @updatedAt
}

enum Channel {
  INAPP
  EMAIL
}

enum PitchStatus {
  DRAFT
  QUEUED
  SENT
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}


enum AgreementSubjectType {
  ARTIST
  CURATOR
}

enum AgreementDocType {
  TERMS
  PRIVACY
  PITCH_CONSENT
  BILLING_TERMS
}

model AgreementAcceptance {
  id          String               @id @default(cuid())
  subjectType AgreementSubjectType
  subjectId   String
  docType     AgreementDocType
  version     String
  acceptedAt  DateTime             @default(now())
  ip          String?
  userAgent   String?
  meta        Json?

  @@unique([subjectType, subjectId, docType, version], name: "subject_doc_version_unique")
  @@index([subjectType, subjectId], name: "subject_lookup")
}

enum MatchJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

model MatchJob {
  id        String         @id @default(cuid())
  status    MatchJobStatus @default(QUEUED)

  // wat moet de job doen
  trackId   String
  artistId  String?

  // scheduling/retry
  runAt     DateTime       @default(now())
  attempts  Int            @default(0)
  maxAttempts Int          @default(5)

  // locking (tegen dubbele verwerking)
  lockedAt  DateTime?
  lockedBy  String?

  // output
  lastError String?
  result    Json?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status, runAt])
  @@index([trackId])
  @@index([lockedAt])
}




